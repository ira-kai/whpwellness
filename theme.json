  "_extractionScript": "To get resolved theme values, open https://www.whpwellness.com in Chrome, press F12, go to Console tab, and paste this script:\n\nconst html = document.documentElement;\nconst cs = getComputedStyle(html);\nconst colors = {};\nfor (let i = 0; i <= 35; i++) { const v = cs.getPropertyValue('--color_' + i).trim(); if (v) colors['color_' + i] = v; }\nfor (let i = 36; i <= 65; i++) { const v = cs.getPropertyValue('--color_' + i).trim(); if (v) colors['color_' + i] = v; }\nconst fonts = {};\nfor (let i = 0; i <= 10; i++) { const v = cs.getPropertyValue('--font_' + i).trim(); if (v) fonts['font_' + i] = v; }\nconsole.log(JSON.stringify({colors, fonts}, null, 2));"
}
